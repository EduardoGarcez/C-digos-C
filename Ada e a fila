Listad *funcao_tofront(Listad*L,int valor)
{
    Listad*L2=NULL;
    L2=cria_listad();
    Nod*aux=NULL;
    insere_fim_listad(L2,valor);
    aux = remove_inicio_listad(L);
    while(aux!=NULL)//REMOVER TODOS OS ELEMENTOS DA LISTA ORIGINAL
    {
        insere_fim_listad(L2,aux->info);
        aux = remove_inicio_listad(L);
    }
    aux = remove_inicio_listad(L2);
    while(aux!=NULL)//REMOVER TODOS OS ELEMENTOS E PASSAR PARA A LISTA ORIGINAL
    {
        insere_fim_listad(L,aux->info);
        aux = remove_inicio_listad(L2);
    }
    return L;
}
Listad *funcao_reverse(Listad*L)
{
    Listad*L2=NULL;
    L2=cria_listad();
    Nod*aux=NULL;
    aux = remove_inicio_listad(L);
    L2 = insere_inicio_listad(L2,aux->info);
    while(aux!=NULL)
    {
        aux = remove_inicio_listad(L);
        L2 = insere_inicio_listad(L2,aux->info);
    }
    aux = remove_inicio_listad(L2);
    L = insere_fim_listad(L,aux->info);
    while(aux!=NULL)
    {
        aux = remove_inicio_listad(L2);
        L = insere_fim_listad(L,aux->info); 
    }
    return L;
}
